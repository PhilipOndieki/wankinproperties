# SMTP — used by /api/inquiries to send email notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=hello@wankinproperties.co.ke
SMTP_PASS=your-smtp-password
SMTP_FROM="Wankin Properties <hello@wankinproperties.co.ke>"
INQUIRY_TO=hello@wankinproperties.co.ke

# Google Maps — embed API key for property maps
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
