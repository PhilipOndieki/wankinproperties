# SMTP — used by /api/inquiries to send email notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=info@wankinproperties.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Wankin Properties <info@wankinproperties.com>"
INQUIRY_TO=info@wankinproperties.com

# Google Maps — embed API key for property maps
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
